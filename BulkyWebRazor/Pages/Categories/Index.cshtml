@page
@model BulkyWebRazor.Pages.Categories.IndexModel

<div class="container">
    <div class="row">
        <div class="col-6 pt-4 pb-3">
            <h2 class="text-primary text-black">
                Category List
            </h2>
        </div>
        <div class="col-6 p-2 pt-4 text-end">
            <a asp-page="/Categories/createcategory"  class="btn btn-primary bg-black">
                <i class="bi bi-plus-circle"></i> Create Category
            </a>
        </div>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Category</th>
                <th>Display Order</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model.CategoryList.OrderBy(u => u.DisplayOrder))
            {
                <tr>
                    <td>@obj.Name</td>
                    <td>@obj.DisplayOrder</td>
                    <td>
                        <div class="btn-group w-75" role="group">
                            <a asp-page="/Categories/Edit"  asp-route-id="@obj.Id" class="btn btn-primary mx-2"><i class="bi bi-pencil-square"></i>Edit</a>
                            @* <a asp-page="/Categories/Delete"  asp-route-id="@obj.Id" class="btn btn-danger mx-2"><i class="bi bi-trash"></i>Delete</a> *@
                            <form method="post" asp-page-handler="Delete" asp-route-id="@obj.Id">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure')"><i class="bi bi-trash"></i>Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

