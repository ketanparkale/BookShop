@model List<Category>; //here we receive the object from controller. model must be in lower case.

<div class="card shadow mt-4">
    <div class="card-header">
        <div class="row text-center">
            <h2 class="text-primary text-black-50 p-2">Category List</h2>
        </div>
    </div>
    <div class="card-body ">
        <div class="row">
            <div class="px-2 pb-3 text-end">
                <a asp-controller="Category" asp-action="Create" class="btn btn-primary bg-black">
                    <i class="bi bi-plus-circle"></i> Create Category
                </a>
            </div>
        </div>
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Display Order</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model.OrderBy(u => u.DisplayOrder))
                {
                    <tr>
                        <td>@obj.Name</td>
                        <td>@obj.DisplayOrder</td>
                        <td>
                            <div class="btn-group w-75" role="group">
                                <a asp-controller="Category" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2"><i class="bi bi-pencil-square"></i>Edit</a>
                                <a asp-controller="Category" asp-action="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2"><i class="bi bi-trash"></i>Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

