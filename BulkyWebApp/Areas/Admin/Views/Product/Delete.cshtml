@model Product;

 <div class="card">
    <div class="card-header">
        <div class="row text-center">
            <h2 class="text-primary text-black-50 p-2">Delete Category</h2>
        </div>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="p-3 mt-2">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="All"></div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="Title" type="text" class="form-control p-1" placeholder="Product Name" />
                    <label asp-for="Title"></label>
                </div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="Description" type="number" class="form-control p-1" placeholder="DisplayOrder" />
                    <label asp-for="Description"></label>
                </div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="ISBN" type="number" class="form-control p-1" placeholder="DisplayOrder" />
                    <label asp-for="ISBN"></label>
                </div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="Author" type="number" class="form-control p-1" placeholder="DisplayOrder" />
                    <label asp-for="Author"></label>
                </div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="ListPrice" type="number" class="form-control p-1" placeholder="DisplayOrder" />
                    <label asp-for="ListPrice"></label>
                </div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="Price" type="number" class="form-control p-1" placeholder="DisplayOrder" />
                    <label asp-for="Price"></label>
                </div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="Price50" type="number" class="form-control p-1" placeholder="DisplayOrder" />
                    <label asp-for="Price50"></label>
                </div>
                <div class="col-12 form-floating py-1">
                    <input asp-for="Price100" type="number" class="form-control p-1" placeholder="DisplayOrder" />
                    <label asp-for="Price100"></label>
                </div>
                <div class="row mt-2">
                    <div class="col-6 col-md-3 p-2">
                        <button type="submit" class="btn btn-danger form-control">Delete</button>
                    </div>

                    <div class="col-6 col-md-3 p-2">
                        <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary form-control">Back To List</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
